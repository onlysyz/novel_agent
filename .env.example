# =============================================================================
# NovelForge Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All parameters are optional with sensible defaults.

# =============================================================================
# Anthropic API Configuration (Required)
# =============================================================================

# Your Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Custom Anthropic API base URL (for proxy/testing)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
# Model Configuration
# =============================================================================

# Model used for writing (drafting, generation)
# Default: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# Model used for deep review and evaluation
# Default: opus-4-5-20251114
CLAUDE_OPUS_MODEL=opus-4-5-20251114

# =============================================================================
# Novel Targets
# =============================================================================

# Target total word count for the complete novel
# Default: 80000
TARGET_WORD_COUNT=80000

# Target number of chapters
# Default: 22
CHAPTER_TARGET=22

# Target words per chapter (used for planning outline)
# Default: 3200
TARGET_WORDS_PER_CHAPTER=3200

# Minimum word count for a chapter to be considered complete
# Default: 2500
MIN_CHAPTER_WORDS=2500

# Maximum word count for a single chapter
# Default: 8000
MAX_CHAPTER_WORDS=8000

# =============================================================================
# Iteration Limits
# =============================================================================

# Maximum iterations for foundation generation (world, characters, etc.)
# If score doesn't reach threshold after this many tries, proceeds anyway
# Default: 15
MAX_FOUNDATION_ITERATIONS=15

# Maximum review/rewrite cycles per chapter
# After this many cycles without improvement, proceeds to next chapter
# Default: 3
MAX_REVIEW_CYCLES=3

# =============================================================================
# Score Thresholds
# =============================================================================

# Minimum score (0-10) required for foundation documents
# Documents below this score will be regenerated up to MAX_FOUNDATION_ITERATIONS
# Default: 7.0
MIN_FOUNDATION_SCORE=7.0

# Minimum score (0-10) required for chapter drafts
# Chapters below this score will be revised up to MAX_REVIEW_CYCLES
# Default: 6.0
MIN_CHAPTER_SCORE=6.0

# =============================================================================
# Output Configuration
# =============================================================================

# Output directory for novel project (default: current directory)
# OUTPUT_DIR=/path/to/your/novel/project

# =============================================================================
# External Services (Optional)
# =============================================================================

# fal.ai API key for cover art generation
# Get yours at https://fal.ai/
# FAL_API_KEY=

# ElevenLabs API key for audiobook narration
# Get yours at https://elevenlabs.io/
# ELEVENLABS_API_KEY=

# =============================================================================
# Environment Variables Summary
# =============================================================================
# | Variable                    | Default           | Description
# |-----------------------------|-------------------|-----------------------
# | ANTHROPIC_API_KEY           | (required)        | Anthropic API key
# | ANTHROPIC_BASE_URL          | api.anthropic.com | API base URL
# | CLAUDE_MODEL                | claude-sonnet-4-  | Writing model
# |                             | 20250514          |
# | CLAUDE_OPUS_MODEL           | opus-4-5-20251114 | Review model
# | TARGET_WORD_COUNT           | 80000             | Novel target length
# | CHAPTER_TARGET              | 22                | Number of chapters
# | TARGET_WORDS_PER_CHAPTER    | 3200              | Per-chapter target
# | MIN_CHAPTER_WORDS           | 2500              | Minimum chapter size
# | MAX_CHAPTER_WORDS           | 4500              | Maximum chapter size
# | MAX_FOUNDATION_ITERATIONS   | 15                | Foundation max tries
# | MAX_REVIEW_CYCLES           | 3                 | Chapter revision limit
# | MIN_FOUNDATION_SCORE        | 7.0               | Foundation pass threshold
# | MIN_CHAPTER_SCORE           | 6.0               | Chapter pass threshold
# | OUTPUT_DIR                  | .                 | Project output path
# | FAL_API_KEY                 | (empty)           | Cover art generation
# | ELEVENLABS_API_KEY          | (empty)           | Audiobook narration